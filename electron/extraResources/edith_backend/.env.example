# E.D.I.T.H. M2 — Environment Template
# =========================================
# Copy this file to .env and fill in your own keys.
# DO NOT commit .env to git.

# ── Required ─────────────────────────────────────────
# Google Gemini API Key (powers Winnie, Paper Dive, Methods Lab, Citations)
# Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── Optional (improves code generation) ──────────────
# OpenAI API Key (GPT-4.1 for Vibe Coder — better Stata/R/Python output)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# ── Optional (citation sync) ────────────────────────
# Mendeley OAuth — create an app at https://dev.mendeley.com
MENDELEY_CLIENT_ID=your_mendeley_client_id
MENDELEY_CLIENT_SECRET=your_mendeley_client_secret
MENDELEY_ACCESS_TOKEN=
MENDELEY_REFRESH_TOKEN=

# ── Optional (note sync) ────────────────────────────
# Notion Internal Integration — https://www.notion.so/my-integrations
NOTION_TOKEN=your_notion_token
NOTION_DATABASE_ID=your_notion_database_id
