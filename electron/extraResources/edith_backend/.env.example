# E.D.I.T.H. M2 — Environment Template
# =========================================
# Copy this file to .env and fill in your own keys.
# DO NOT commit .env to git.

# ══════════════════════════════════════════
# REQUIRED — Winnie and all AI features
# ══════════════════════════════════════════

# Google Gemini API Key
# Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ══════════════════════════════════════════
# RECOMMENDED — Better code generation
# ══════════════════════════════════════════

# OpenAI API Key (GPT-4.1 for Vibe Coder code generation)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# Fine-Tuned OpenAI Model (optional — see SETUP_GUIDE.md Part 7)
# If you fine-tune your own Winnie model, put the model ID here
# Example: ft:gpt-4o-2024-08-06:personal:winnie-v8:XXXXXXXX
OPENAI_FT_MODEL=

# ══════════════════════════════════════════
# OPTIONAL — Search & Research Tools
# ══════════════════════════════════════════

# OpenAlex (free, no key needed for basic use)
# Optional: add an email for the polite pool (faster rate limits)
OPENALEX_POLITE_EMAIL=user@example.com

# Semantic Scholar API Key (higher rate limits for citation search)
# Get one at: https://www.semanticscholar.org/product/api#Partner-Form
SEMANTIC_SCHOLAR_API_KEY=

# LegiScan API Key (US legislation search)
# Get one at: https://legiscan.com/legiscan
LEGISCAN_API_KEY=

# New York Times API Key (news search)
# Get one at: https://developer.nytimes.com/get-started
NYT_API_KEY=

# SerpAPI Key (Google Scholar search)
# Get one at: https://serpapi.com
SERPAPI_KEY=

# Perplexity API Key (AI-powered search)
# Get one at: https://docs.perplexity.ai
PERPLEXITY_API_KEY=

# ══════════════════════════════════════════
# OPTIONAL — Reference Managers
# ══════════════════════════════════════════

# Mendeley OAuth (citation library sync)
# Create an app at: https://dev.mendeley.com
MENDELEY_CLIENT_ID=
MENDELEY_CLIENT_SECRET=
MENDELEY_ACCESS_TOKEN=
MENDELEY_REFRESH_TOKEN=

# Zotero API Key (alternative citation manager)
# Get one at: https://www.zotero.org/settings/keys
ZOTERO_API_KEY=

# ══════════════════════════════════════════
# OPTIONAL — Integrations
# ══════════════════════════════════════════

# Notion API (note sync)
# Create integration at: https://www.notion.so/my-integrations
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Overleaf Git Token (LaTeX sync)
# Get one from your Overleaf account settings
OVERLEAF_GIT_TOKEN=

# Overleaf Project URL (single project — legacy)
# Example: https://git.overleaf.com/<project_id>
OVERLEAF_PROJECT_URL=

# Overleaf Projects (multi-project support — JSON)
# Example: {"American Politics":"https://git.overleaf.com/abc123","Methods":"https://git.overleaf.com/def456"}
OVERLEAF_PROJECTS=

# Anthropic API Key (Claude — alternative LLM)
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Mathpix API Key (OCR for equations in PDFs)
# Get one at: https://accounts.mathpix.com
MATHPIX_APP_KEY=

# Google Earth Engine (spatial/GIS features)
# Get one at: https://earthengine.google.com
GOOGLE_EARTH_ENGINE_KEY=

# Sentry DSN (error monitoring — for developers)
# Get one at: https://sentry.io
SENTRY_DSN=

# ══════════════════════════════════════════
# MODEL CONFIGURATION (defaults work fine)
# ══════════════════════════════════════════

# EDITH_MODEL=gemini-2.5-flash
# EDITH_ORACLE_MODEL=gemini-2.5-pro
# EDITH_CODE_MODEL=gpt-4.1
# WINNIE_OPENAI_MODEL=gpt-4.1
# WINNIE_GEMINI_MODEL=gemini-2.5-flash
